PORT=5000
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster.mongodb.net/mediqueueai
JWT_SECRET=your_jwt_secret_change_this

GEMINI_API_KEY=your_gemini_api_key_optional

# Gmail SMTP - Google Account > Security > App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourhospital@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=MediQueueAI <yourhospital@gmail.com>

ADMIN_EMAIL=admin@mediqueueai.com

# Set this to your Vercel frontend URL after deploying frontend
FRONTEND_URL=https://your-frontend.vercel.app

NODE_ENV=production
